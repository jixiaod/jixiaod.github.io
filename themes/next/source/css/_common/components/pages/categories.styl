.category-all-page {
  .category-all-title { text-align: center; }

  .category-all { padding:0 0 0 80px;}

  .category-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .category-list-item { margin: 5px 10px; font-size:18px;}

  .category-list-count {
    color: $grey;
    &:before {
      display: inline;
      content: " ("
    }
    &:after {
      display: inline;
      content: ") "
    }
  }

  .category-list-child { padding-left: 10px; }
}
